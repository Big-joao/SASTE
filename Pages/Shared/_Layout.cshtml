@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SASTE</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="SASTE-body">
    @if (SignInManager.IsSignedIn(User))
    {
        <div class="SASTE-app">
            <aside class="SASTE-sidebar">
                <div class="SASTE-logo">
                    <img src="~/images/logo-SASTE.png" alt="SASTE" />
                    <span>SASTE</span>
                </div>

                <nav class="SASTE-nav">
                    <a asp-page="/Index">Dashboard</a>
                    <a asp-page="/Admin/Index">Admin</a>
                    <a asp-page="/Sales/Index">Vendas</a>
                    <a asp-page="/Warehouse/Index">Armazém</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-page="/Products/Index">Produtos</a>
                        <a asp-page="/Admin/Users">Utilizadores</a>
                    }
                </nav>
            </aside>

            <div class="SASTE-main">
                <header class="SASTE-topbar">
                    <div>
                        <h5 class="mb-0">@ViewData["Title"]</h5>
                    </div>
                    <div class="SASTE-userbox">
                        <span>@User.Identity?.Name</span>
                        <form method="post" asp-area="Identity" asp-page="/Account/Logout">
                            <button type="submit" class="btn btn-sm btn-outline-dark">Logout</button>
                        </form>
                    </div>
                </header>

                <main class="SASTE-content">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <header class="bg-white shadow-sm p-3 mb-4 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <img src="~/images/logo-SASTE.png" alt="SASTE" style="width: 42px; height: 42px; object-fit: contain;" />
                <h4 class="mb-0 fw-bold" style="color: #0d6efd;">SASTE</h4>
            </div>
            <div>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary me-2">Entrar</a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-success" style="background-color: #20c997; border-color: #20c997;">Registar</a>
            </div>
        </header>

        <main class="container mt-4">
            @RenderBody()
        </main>
    }

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>